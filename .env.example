# NatWest ForeSight Enterprise AI Configuration
# Copy this file to .env and fill in your keys

# --- Core API Settings ---
API_HOST=127.0.0.1
API_PORT=8000
APP_ENV=production

# --- AI / LLM Configuration (NVIDIA NIM) ---
# Required by Vanna for Text-to-SQL generation and by the analyst layer for explanations
# Get your key at: https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_api_key_here
NIM_MODEL=meta/llama-3.1-8b-instruct
NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# --- Database / Storage Configuration ---
# Internal Docker DSN (for the backend)
POSTGRES_DSN=postgresql://admin:adminpassword@postgres:5432/natwest_db

# Local paths (managed by bootstrap script)
DATA_DIR=data
DUCKDB_PATH=data/demo.duckdb

# --- Feature Flags ---
ENABLE_STARTUP_REFRESH=false
DEFAULT_ROW_CAP=500
QUERY_TIMEOUT_S=120

# --- Service URLs (all-in-docker topology defaults) ---
MINDSDB_API_URL=http://mindsdb:47334/api/sql/query
AIRFLOW_BASE_URL=http://airflow-webserver:8080
AIRFLOW_USERNAME=airflow
AIRFLOW_PASSWORD=airflow
CUBE_BASE_URL=http://cubejs:4000

# --- Connection profile storage ---
CONNECTION_PROFILES_PATH=data/cache/connection_profiles.json
DEFAULT_CONNECTION_TYPE=duckdb
